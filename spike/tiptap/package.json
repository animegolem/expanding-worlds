{
  "name": "ew-tiptap-spike",
  "private": true,
  "type": "module",
  "description": "Throwaway TipTap go/no-go spike for AI-IMP-144. Findings transfer via RAG/spike-reports/tiptap-verdict.md; code does not. Self-contained npm project, OUTSIDE the pnpm workspace (root globs apps/* packages/* only) so the app dependency tree is untouched.",
  "scripts": {
    "test": "vitest run",
    "perf": "node --expose-gc ./src/perf.mjs",
    "bundle": "node ./src/measure-bundle.mjs",
    "electron": "electron ./src/electron-main.cjs"
  },
  "devDependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "tiptap-markdown": "^0.8.10",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8",
    "electron": "^33.2.1",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.5"
  }
}
