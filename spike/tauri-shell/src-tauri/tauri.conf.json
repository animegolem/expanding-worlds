{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ew-tauri-shell-spike",
  "version": "0.1.0",
  "identifier": "com.expandingworlds.tauri-shell-spike",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5200",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EW Tauri Shell Spike",
        "width": 1440,
        "height": 900,
        "x": 4000,
        "y": 200,
        "focus": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.png"]
  }
}
