{
  "name": "expanding-worlds",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "check": "pnpm build && pnpm test && pnpm lint && pnpm check:spike",
    "check:ci": "pnpm build && pnpm -r --filter '!@ew/desktop' test && pnpm lint && pnpm check:spike",
    "check:spike": "npm --prefix spike exec --no -- tsc --noEmit -p spike/tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  }
}
