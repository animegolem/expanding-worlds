{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/board/**",
              "components/chrome/**",
              "components/controls/**",
              "components/feedback/**",
              "components/panels/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Charm'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|label|active|deferred|warn|count|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Charm> doesn't accept that prop. Declared props: glyph, label, active, deferred, warn, count, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CharmBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:noteActive|onAction|style|key|ref|className|style|children)$/]",
        "message": "<CharmBar> doesn't accept that prop. Declared props: noteActive, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CharmRail'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|conditionCount|floating|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<CharmRail> doesn't accept that prop. Declared props: active, conditionCount, floating, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dock'] > JSXAttribute > JSXIdentifier[name!=/^(?:activeTool|zoomPct|shapeGlyph|floating|onTool|onZoom|style|key|ref|className|style|children)$/]",
        "message": "<Dock> doesn't accept that prop. Declared props: activeTool, zoomPct, shapeGlyph, floating, onTool, onZoom, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FacetChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|on|tag|onToggle|onClear|style|key|ref|className|style|children)$/]",
        "message": "<FacetChip> doesn't accept that prop. Declared props: label, on, tag, onToggle, onClear, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuPopover'] > JSXAttribute > JSXIdentifier[name!=/^(?:rows|style|key|ref|className|style|children)$/]",
        "message": "<MenuPopover> doesn't accept that prop. Declared props: rows, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NodeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|src|stripes|width|height|label|hasNote|hasCanvas|selected|hit|dimmed|onClick|style|key|ref|className|style|children)$/]",
        "message": "<NodeCard> doesn't accept that prop. Declared props: title, src, stripes, width, height, label, hasNote, hasCanvas, selected, hit, dimmed, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NotePanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|tags|places|pinned|origin|dirty|width|height|children|onPin|onClose|style|key|ref|className|style|children)$/]",
        "message": "<NotePanel> doesn't accept that prop. Declared props: title, tags, places, pinned, origin, dirty, width, height, children, onPin, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|headerExtra|width|children|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, headerExtra, width, children, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PathBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:crumbs|pinOpen|floating|onCrumb|onPin|style|key|ref|className|style|children)$/]",
        "message": "<PathBar> doesn't accept that prop. Declared props: crumbs, pinOpen, floating, onCrumb, onPin, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Segmented'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Segmented> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TagChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|on|onClick|style|key|ref|className|style|children)$/]",
        "message": "<TagChip> doesn't accept that prop. Declared props: tag, on, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|placeholder|pill|prefix|onChange|style|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: value, placeholder, pill, prefix, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|kind|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: children, kind, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TooltipChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|shortcut|style|key|ref|className|style|children)$/]",
        "message": "<TooltipChip> doesn't accept that prop. Declared props: name, shortcut, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
